{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext", 
    "moduleResolution": "NodeNext",
    "rootDir": "./",
    "outDir": "./dist",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["index.ts", "src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"]
}

{
  "name": "buscohuella-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo Institucional BuscoHuella",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "web:dev": "pnpm --filter @buscohuella/web dev",
    "web:build": "pnpm --filter @buscohuella/web build",
    "app:start": "pnpm --filter @buscohuella/app start",
    "shared:test": "pnpm --filter @buscohuella/shared test",
    "structure": "powershell ./scripts/update-structure.ps1",
    "context": "powershell ./scripts/generate-context.ps1",
    "health": "node scripts/health-check.mjs",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.27",
    "jsdom": "^26.1.0",
    "msw": "^2.8.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "typescript": "^5.7.2",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "inflight": "^1.0.6",
      "next": "16.2.0",
      "react": "19.2.3",
      "react-dom": "19.2.3"
    },
    "ignoredBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@notionhq/client": "^5.12.0",
    "@supabase/supabase-js": "^2.99.1",
    "dotenv": "^17.3.1"
  }
}